        // Zeile 2: Inputs + Button
        const inputRow=mk('div','',`display:flex;gap:8px;align-items:center;`);
        function mkSrch(ph,w){
            const i=mk('input','',`height:32px;padding:0 10px;background:#0f1520;border:1px solid #2a3a55;border-radius:4px;color:#c8d4e8;font-size:13px;font-family:monospace;outline:none;${w?'width:'+w+';flex-shrink:0;':'flex:1;'}`);
            i.placeholder=ph;
            i.addEventListener('focus',()=>i.style.borderColor='#4a7ab5');
            i.addEventListener('blur',()=>i.style.borderColor='#2a3a55');
            return i;
        }
        const pInp=mkSrch('z.B. 285706','240px');
        const dInp=mkSrch('z.B. top pad');
        const goBtn=dBtn('🔍 Suchen','#1a3a6a','#1e4d8a');goBtn.style.cssText+='height:32px;flex-shrink:0;';
        inputRow.appendChild(pInp);inputRow.appendChild(dInp);inputRow.appendChild(goBtn);

        searchRow.appendChild(labelRow);
        searchRow.appendChild(inputRow);

        const status=mk('div','',`padding:6px 14px;color:#3a5a8a;font-size:12px;font-style:italic;background:#151b27;border-bottom:1px solid #2a3447;flex-shrink:0;min-height:28px;`);
        status.textContent='Partnummer und/oder Beschreibung eingeben → Enter oder Suchen.';


        const colHdr=mk('div','',`display:grid;grid-template-columns:130px 1fr 100px 60px 48px 80px;padding:5px 14px;background:#0f1520;border-bottom:1px solid #2a3447;font-size:11px;font-weight:700;color:#3a5a8a;letter-spacing:.5px;text-transform:uppercase;flex-shrink:0;gap:8px;`);
        ['Partnummer','Beschreibung','Klasse','UOM','Bild',''].forEach(h=>{const c=mk('span');c.textContent=h;colHdr.appendChild(c);});

        const results=mk('div','',`overflow-y:auto;flex:1;background:#1a2030;`);
        container.appendChild(searchRow);container.appendChild(status);container.appendChild(colHdr);container.appendChild(results);

        async function doSearch(){
            const pq=pInp.value.trim(), dq=dInp.value.trim();
            if(!pq&&!dq)return;
            status.style.color='#3a5a8a';status.textContent='⏳ Suche läuft…';results.innerHTML='';
            const data=await searchEAM(pq, dq);
            if(!data.length){status.style.color='#e05555';status.textContent='Keine Treffer in EAM.';return;}
            status.style.color='#4a7a4a';status.textContent=`${data.length} Treffer`;
            data.forEach(r=>{
                const saved=partcodeMap.some(e=>e.part===r.part);
                const row=mk('div','',`display:grid;grid-template-columns:130px 1fr 100px 60px 48px 80px;padding:7px 14px;border-bottom:1px solid #1e2a3a;align-items:center;font-size:13px;gap:8px;transition:background .1s;${saved?'opacity:.5;':''}`);
                row.addEventListener('mouseenter',()=>row.style.background='#232d3f');
                row.addEventListener('mouseleave',()=>row.style.background='');
                const p1=mk('span','',`color:#6ba3e8;font-weight:700;font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;`);p1.textContent=r.part;
                const p2=mk('span','',`color:#8899bb;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;`);p2.textContent=r.desc;
                const p3=mk('span','',`padding:1px 7px;border-radius:3px;font-size:11px;font-weight:700;background:#1a2540;color:#5a8adc;font-family:monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;`);p3.textContent=r.class||'—';
                const p4=mk('span','',`color:#556;font-size:12px;`);p4.textContent=r.uom;
                // Bild-Zelle
                const imgCell=mk('div','',`width:48px;height:40px;display:flex;align-items:center;justify-content:center;`);
                if(r.pic){
                    const img=mk('img','',`width:40px;height:40px;object-fit:contain;border-radius:3px;border:1px solid #2a3a55;cursor:zoom-in;transition:transform .15s;`);
                    img.src=`https://eu1.eam.hxgnsmartcloud.com/web/base/VIEWUDOC?documentcode=${encodeURIComponent(r.pic)}&keepcontenttype=true&eamid=${r.eamid}`;
                    img.onerror=()=>{imgCell.textContent='—';imgCell.style.cssText+='color:#334;font-size:12px;text-align:center;';};
                    img.addEventListener('mouseenter',()=>img.style.transform='scale(3) translateX(-8px)');
                    img.addEventListener('mouseleave',()=>img.style.transform='');
                    imgCell.appendChild(img);
                } else {
                    imgCell.textContent='—';imgCell.style.cssText+='color:#334;font-size:12px;text-align:center;';
                }
                // action cell: + oder ✓+−
                const actionCell=mk('div','',`display:flex;gap:4px;align-items:center;`);
                if(saved){
                    const ck=mk('button','',`width:30px;height:30px;background:#1a2030;border:1px solid #2a3040;border-radius:4px;color:#4a7a4a;font-size:13px;display:flex;align-items:center;justify-content:center;cursor:default;`);
                    ck.textContent='✓';ck.title='Bereits gespeichert';
                    const rm=mk('button','',`width:30px;height:30px;background:#3a1a1a;border:1px solid #7a2828;border-radius:4px;color:#e05555;font-size:16px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .15s;`);
                    rm.textContent='−';rm.title='Aus DB entfernen';
                    rm.addEventListener('mouseenter',()=>rm.style.background='#5a1a1a');
                    rm.addEventListener('mouseleave',()=>rm.style.background='#3a1a1a');
                    rm.onclick=()=>{
                        const idx=partcodeMap.findIndex(e=>e.part===r.part);
                        if(idx>=0){partcodeMap.splice(idx,1);saveMap(partcodeMap);}
                        row.style.opacity='1';
                        ck.style.color='#334';rm.remove();ck.textContent='';
                        // reset zu + button
                        const nb=mk('button','',`width:30px;height:30px;background:#1d6b38;border:1px solid #27964e;border-radius:4px;color:white;font-size:14px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .15s;`);
                        nb.textContent='＋';nb.title='Zu Meine DB hinzufügen';
                        nb.addEventListener('mouseenter',()=>nb.style.background='#27964e');
                        nb.addEventListener('mouseleave',()=>nb.style.background='#1d6b38');
                        nb.onclick=()=>{
                            const alias=prompt(`Alias für "${r.part}":\n(leer = Partnummer wird als Key verwendet)`,r.part.toLowerCase())??'';
                            const key=(alias.trim()||r.part).toLowerCase();
                            partcodeMap.push({key,part:r.part,desc:r.desc});saveMap(partcodeMap);
                            toast(`✅ "${r.part}" gespeichert als "${key}"`);
                        };
                        actionCell.appendChild(nb);
                        toast(`🗑️ "${r.part}" entfernt`);
                    };
                    actionCell.appendChild(ck);actionCell.appendChild(rm);
                } else {
                    const ab=mk('button','',`width:30px;height:30px;background:#1d6b38;border:1px solid #27964e;border-radius:4px;color:white;font-size:14px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .15s;`);
                    ab.textContent='＋';ab.title='Zu Meine DB hinzufügen';
                    ab.addEventListener('mouseenter',()=>ab.style.background='#27964e');
                    ab.addEventListener('mouseleave',()=>ab.style.background='#1d6b38');
                    ab.onclick=()=>{
                        const alias=prompt(`Alias für "${r.part}":\n(leer = Partnummer wird als Key verwendet)`,r.part.toLowerCase())??'';
                        const key=(alias.trim()||r.part).toLowerCase();
                        partcodeMap.push({key,part:r.part,desc:r.desc});saveMap(partcodeMap);
                        ab.remove();
                        const ck2=mk('button','',`width:30px;height:30px;background:#1a2030;border:1px solid #2a3040;border-radius:4px;color:#4a7a4a;font-size:13px;display:flex;align-items:center;justify-content:center;cursor:default;`);
                        ck2.textContent='✓';
                        const rm2=mk('button','',`width:30px;height:30px;background:#3a1a1a;border:1px solid #7a2828;border-radius:4px;color:#e05555;font-size:16px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:background .15s;`);
                        rm2.textContent='−';rm2.addEventListener('mouseenter',()=>rm2.style.background='#5a1a1a');rm2.addEventListener('mouseleave',()=>rm2.style.background='#3a1a1a');
                        rm2.onclick=()=>{const idx=partcodeMap.findIndex(e=>e.part===r.part);if(idx>=0){partcodeMap.splice(idx,1);saveMap(partcodeMap);}rm2.remove();ck2.remove();actionCell.appendChild(ab);row.style.opacity='1';toast(`🗑️ "${r.part}" entfernt`);};
                        actionCell.appendChild(ck2);actionCell.appendChild(rm2);
                        row.style.opacity='.5';toast(`✅ "${r.part}" gespeichert als "${key}"`);
                    };
                    actionCell.appendChild(ab);
                }
                [p1,p2,p3,p4,imgCell,actionCell].forEach(c=>row.appendChild(c));results.appendChild(row);
            });
        }
        let _liveDs=null;
        function triggerLive(){clearTimeout(_liveDs);_liveDs=setTimeout(doSearch,250);}
        goBtn.onclick=doSearch;
        [pInp,dInp].forEach(i=>{
            i.addEventListener('keydown',e=>{if(e.key==='Enter')doSearch();});
            i.addEventListener('input',triggerLive);
        });
        setTimeout(()=>dInp.focus(),80);
    }

    // HELPERS
    function mk(tag,id='',style=''){const e=document.createElement(tag);if(id)e.id=id;if(style)e.style.cssText=style;return e;}
    function dBtn(text,bg,bgh){const b=mk('button','',`padding:6px 14px;background:${bg};color:#d0daf0;border:none;border-radius:4px;cursor:pointer;font-size:13px;font-weight:600;transition:background .15s;white-space:nowrap;`);b.innerHTML=text;b.addEventListener('mouseenter',()=>b.style.background=bgh);b.addEventListener('mouseleave',()=>b.style.background=bg);return b;}
    function iBtn(icon,bg,bgh,title){const b=mk('button','',`width:34px;height:34px;background:${bg};border:none;border-radius:4px;cursor:pointer;font-size:15px;color:white;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:background .15s;`);b.innerHTML=icon;b.title=title;b.addEventListener('mouseenter',()=>b.style.background=bgh);b.addEventListener('mouseleave',()=>b.style.background=bg);return b;}
    function dkInp(value,width,placeholder,forceLower){const i=mk('input','',`width:${width};padding:5px 8px;background:#0f1520;border:1px solid #2a3a55;border-radius:4px;color:#c8d4e8;font-size:13px;font-family:monospace;flex-shrink:0;${forceLower?'text-transform:lowercase;':''}`);i.value=value;i.placeholder=placeholder;i.addEventListener('focus',()=>i.style.borderColor='#4a7ab5');i.addEventListener('blur',()=>i.style.borderColor='#2a3a55');if(forceLower)i.addEventListener('input',()=>{const p=i.selectionStart;i.value=i.value.toLowerCase();i.setSelectionRange(p,p);});i.addEventListener('mousedown',e=>e.stopPropagation(),true);i.addEventListener('click',e=>e.stopPropagation(),true);return i;}
    function doExport(){const b=new Blob([JSON.stringify(partcodeMap,null,2)],{type:'application/json'});const a=Object.assign(document.createElement('a'),{href:URL.createObjectURL(b),download:'partcodes_export.json'});a.click();URL.revokeObjectURL(a.href);toast('📤 Exportiert!');}
    function doImport(){const i=Object.assign(document.createElement('input'),{type:'file',accept:'.json'});i.onchange=e=>{const file=e.target.files[0];if(!file)return;const r=new FileReader();r.onload=ev=>{try{let imp=JSON.parse(ev.target.result);if(!Array.isArray(imp))imp=Object.entries(imp).map(([k,v])=>({key:k,part:v.part,desc:v.desc||''}));if(confirm(`${imp.length} Einträge importieren?`)){partcodeMap.push(...imp);saveMap(partcodeMap);toast('📥 Import ok!');}}catch(err){alert('Fehler: '+err.message);}};r.readAsText(file);};i.click();}
    function toast(msg){const t=mk('div','',`position:fixed;bottom:28px;left:50%;transform:translateX(-50%);background:#1a2a3a;border:1px solid #2a4060;color:#c0d8f8;padding:10px 22px;border-radius:6px;font-size:14px;z-index:2000000;box-shadow:0 4px 12px rgba(0,0,0,.5);white-space:nowrap;`);t.textContent=msg;document.body.appendChild(t);setTimeout(()=>{t.style.transition='opacity .3s';t.style.opacity='0';setTimeout(()=>t.remove(),300);},2200);}

    // EVENTS & INIT
    const sty=document.createElement('style');
    sty.textContent='#pc-ac::-webkit-scrollbar,#pc-overlay *::-webkit-scrollbar{width:5px}#pc-ac::-webkit-scrollbar-track,#pc-overlay *::-webkit-scrollbar-track{background:#0f1520}#pc-ac::-webkit-scrollbar-thumb,#pc-overlay *::-webkit-scrollbar-thumb{background:#2a3a55;border-radius:3px}#pc-overlay input::placeholder{color:#334!important}';
    document.head.appendChild(sty);
    document.addEventListener('input',e=>{const i=e.target;if(i.name!=='partcode'||editorOpen)return;if(i.value.length>=1)showDrop(i,i.value);else removeDrop();},true);
    document.addEventListener('click',e=>{if(editorOpen)return;if(activeDrop&&!activeDrop.contains(e.target)&&e.target!==activeInp)removeDrop();});
    document.addEventListener('keydown',e=>{if(e.key==='Escape'||e.key==='Tab')removeDrop();},true);
    function init(){injectBtn();setTimeout(injectBtn,1000);setTimeout(injectBtn,3000);}
    document.readyState==='loading'?document.addEventListener('DOMContentLoaded',init):init();
    new MutationObserver(()=>injectBtn()).observe(document.body,{childList:true,subtree:true});
    console.log('[Partcode v5.9] Ready. Session:',getSession()?.eamid?.slice(0,8)||'NOT FOUND');
})();
