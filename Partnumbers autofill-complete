            t.dataset.tab=id;t.innerHTML=label;
            t.addEventListener('mouseenter',()=>{if(activeTab!==id)t.style.color='#9ab0cc';});
            t.addEventListener('mouseleave',()=>{if(activeTab!==id)t.style.color='#6a7a9a';});
