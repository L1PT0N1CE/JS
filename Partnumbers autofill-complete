    function loadPartcodeMap() {
        try {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored) return JSON.parse(stored);
        } catch (e) {
            console.warn('[Partcode] Fehler beim Laden:', e);
        }
        return JSON.parse(JSON.stringify(defaultPartcodeMap));
    }

    function savePartcodeMap(map) {
        try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(map));
            return true;
        } catch (e) {
            console.error('[Partcode] Fehler beim Speichern:', e);
            return false;
        }
    }

    let partcodeMap = loadPartcodeMap();

    // ═══════════════════════════════════════════════════════
    // AUTOCOMPLETE LOGIK
    // ═══════════════════════════════════════════════════════
    let activeDropdown = null;
    let activeInput    = null;
    let isEditorOpen   = false;

    function createDropdown(input) {
        removeDropdown();
        const rect     = input.getBoundingClientRect();
        const dropdown = document.createElement('div');
        dropdown.id    = 'partcode-autocomplete';
        dropdown.style.cssText = `
            position: fixed;
            top: ${rect.bottom + window.scrollY}px;
            left: ${rect.left + window.scrollX}px;
            width: ${rect.width}px;
            max-height: 300px;
            overflow-y: auto;
            background: #fff;
            border: 1px solid #ccc;
            border-top: none;
            border-radius: 0 0 4px 4px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.15);
            z-index: 999999;
            font-family: Arial, sans-serif;
            font-size: 13px;
        `;
        activeDropdown = dropdown;
        activeInput    = input;
        document.body.appendChild(dropdown);
        return dropdown;
    }

    function removeDropdown() {
        if (activeDropdown) {
            activeDropdown.remove();
            activeDropdown = null;
            activeInput    = null;
        }
    }

    function populateDropdown(input, query) {
        const dropdown = createDropdown(input);
        const q        = query.toLowerCase().trim();

        const matches = partcodeMap.filter(entry => {
            return entry.key.toLowerCase().includes(q)
                || entry.desc.toLowerCase().includes(q)
                || entry.part.toLowerCase().includes(q);
        });

        if (matches.length === 0) {
            const empty = document.createElement('div');
            empty.style.cssText = 'padding: 10px; color: #999; font-style: italic;';
            empty.textContent   = 'Keine Treffer...';
            dropdown.appendChild(empty);
            return;
        }

        matches.forEach((entry) => {
            const item         = document.createElement('div');
            item.className     = 'partcode-item';
            item.dataset.key   = entry.key;
            item.dataset.part  = entry.part;
            item.style.cssText = `
                padding: 8px 12px;
                cursor: pointer;
                border-bottom: 1px solid #eee;
                display: flex;
                justify-content: space-between;
                align-items: center;
                user-select: none;
            `;
            item.addEventListener('mouseenter', () => item.style.backgroundColor = '#e3f2fd');
            item.addEventListener('mouseleave', () => item.style.backgroundColor = '#fff');
            item.addEventListener('mousedown', (e) => {
                e.stopImmediatePropagation();
                e.preventDefault();
                if (activeInput) selectPartcode(activeInput, item.dataset.key, item.dataset.part);
            }, true);
            item.innerHTML = `
                <span>
                    <strong style="color: #1976d2;">${entry.key}</strong>
                    <span style="color: #666; margin-left: 8px;">${entry.desc}</span>
                </span>
                <span style="color: #888; font-size: 11px; font-family: monospace;">${entry.part}</span>
            `;
            dropdown.appendChild(item);
        });
    }

