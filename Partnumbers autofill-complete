        activeDrop=d;activeInp=input;
        document.body.appendChild(d);
        const q=query.toLowerCase().trim();
        const local=partcodeMap.filter(e=>e.key.toLowerCase().includes(q)||e.desc.toLowerCase().includes(q)||e.part.toLowerCase().includes(q));
        if(local.length){
            const lbl=mk('div','',`padding:3px 12px;background:#111820;color:#4a7a4a;font-size:10px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;`);lbl.textContent='Gespeichert';d.appendChild(lbl);
            local.forEach(e=>{
                const it=mk('div','',`padding:7px 14px;cursor:pointer;border-bottom:1px solid #1e2a3a;display:flex;justify-content:space-between;`);
