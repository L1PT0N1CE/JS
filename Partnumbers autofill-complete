    function selectPart(input,part){
        input.value=part;input.dispatchEvent(new Event('change',{bubbles:true}));
        try{const id=input.getAttribute('data-componentid');if(id&&typeof Ext!=='undefined'){const c=Ext.getCmp(id);if(c?.setValue)c.setValue(part);}}catch(_){}
        input.style.backgroundColor='#1a3a2a';setTimeout(()=>input.style.backgroundColor='',700);
        removeDrop();setTimeout(()=>setExt('transactionquantity','1'),500);
    }
    function setExt(name,val){
        if(typeof Ext!=='undefined'&&Ext.ComponentQuery){const c=Ext.ComponentQuery.query(`[name="${name}"]`)[0];if(c?.setValue){c.setValue(val);return;}}
        const e=document.querySelector(`input[name="${name}"]`);if(e){e.value=val;e.dispatchEvent(new Event('change',{bubbles:true}));}
    }

