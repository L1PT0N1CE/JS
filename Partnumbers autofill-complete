    function createToolbarButton(text, color) {
        const btn = document.createElement('button');
        btn.textContent   = text;
        btn.style.cssText = `
            padding: 6px 12px;
            background: ${color};
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
        `;
        return btn;
    }

    function createIconButton(icon, color, title) {
        const btn = document.createElement('button');
        btn.textContent   = icon;
        btn.title         = title;
        btn.style.cssText = `
            width: 32px;
            height: 32px;
            border: none;
            background: ${color};
            color: white;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        `;
        return btn;
    }

    function createInlineInput(value, width, placeholder, forceLower = false) {
        const input       = document.createElement('input');
        input.value       = value;
        input.placeholder = placeholder;
        input.style.cssText = `
            width: ${width};
            padding: 6px 8px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 13px;
            font-family: monospace;
            flex-shrink: 0;
            ${forceLower ? 'text-transform: lowercase;' : ''}
        `;

        if (forceLower) {
            input.addEventListener('input', () => {
                const pos   = input.selectionStart;
                input.value = input.value.toLowerCase();
                input.setSelectionRange(pos, pos);
            });
        }

        input.addEventListener('mousedown', (e) => e.stopPropagation(), true);
        input.addEventListener('click',     (e) => e.stopPropagation(), true);
        return input;
    }

    function exportJSON() {
        const dataStr = JSON.stringify(partcodeMap, null, 2);
        const blob    = new Blob([dataStr], { type: 'application/json' });
        const url     = URL.createObjectURL(blob);
        const a       = document.createElement('a');
        a.href        = url;
        a.download    = 'partcodes_export.json';
        a.click();
        URL.revokeObjectURL(url);
        showToast('📤 Exportiert!');
    }

    function importJSON() {
        const input  = document.createElement('input');
        input.type   = 'file';
        input.accept = '.json';
        input.onchange = (e) => {
            const file = e.target.files[0];
            if (!file) return;
            const reader    = new FileReader();
            reader.onload   = (event) => {
                try {
                    const imported = JSON.parse(event.target.result);
                    let entries    = [];

                    if (Array.isArray(imported)) {
                        for (const item of imported) {
                            if (typeof item !== 'object' || !item.key || !item.part) {
                                throw new Error('Ungültiges Array-Format: jedes Element braucht "key" und "part"');
                            }
                        }
                        entries = imported;
                    } else {
                        // ✅ Altes Objekt-Format konvertieren
                        for (const [key, val] of Object.entries(imported)) {
                            if (typeof val !== 'object' || !val.part) {
                                throw new Error(`Ungültiges Format bei "${key}"`);
                            }
                            entries.push({ key, part: val.part, desc: val.desc || '' });
                        }
                    }

                    if (confirm(`${entries.length} Einträge importieren?`)) {
                        partcodeMap.push(...entries);
                        savePartcodeMap(partcodeMap);
                        if (currentEditorList) editorRefreshList(currentEditorList);
                        showToast('📥 Import erfolgreich!');
                    }
                } catch (err) {
                    alert('Fehler beim Import: ' + err.message);
                }
            };
            reader.readAsText(file);
        };
        input.click();
    }

    function showToast(msg) {
        const toast       = document.createElement('div');
        toast.textContent = msg;
        toast.style.cssText = `
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%);
            background: #333;
            color: white;
            padding: 12px 24px;
            border-radius: 6px;
            font-size: 14px;
            z-index: 1000001;
            animation: slideUp 0.3s ease;
        `;
        document.body.appendChild(toast);
        setTimeout(() => {
            toast.style.transition = 'opacity 0.3s';
            toast.style.opacity    = '0';
            setTimeout(() => toast.remove(), 300);
        }, 2000);
    }

    const style = document.createElement('style');
    style.textContent = `
        @keyframes slideUp {
            from { transform: translateX(-50%) translateY(20px); opacity: 0; }
            to   { transform: translateX(-50%) translateY(0);    opacity: 1; }
        }
    `;
    document.head.appendChild(style);

    // ═══════════════════════════════════════════════════════
    // EXT HILFSFUNKTIONEN
    // ═══════════════════════════════════════════════════════
    function getExtComponent(name) {
        if (typeof Ext === 'undefined' || !Ext.ComponentQuery) return null;
        const cmps = Ext.ComponentQuery.query('[name="' + name + '"]');
        return cmps && cmps.length > 0 ? cmps[0] : null;
    }

    function setExtFieldValue(name, value) {
        const cmp = getExtComponent(name);
        if (!cmp) {
            const input = document.querySelector('input[name="' + name + '"]');
            if (input) {
                input.value = value;
                input.dispatchEvent(new Event('change', { bubbles: true }));
            }
            return false;
        }
        if (cmp.setValue)   cmp.setValue(value);
        if (cmp.fireEvent)  cmp.fireEvent('change', cmp, value);
        const inputEl = document.querySelector('input[name="' + name + '"]');
        if (inputEl) {
            inputEl.style.backgroundColor = '#d4edda';
            inputEl.style.transition      = 'background-color 0.3s';
            setTimeout(() => inputEl.style.backgroundColor = '', 600);
        }
        return true;
    }

    function autoFillQuantity() {
        setExtFieldValue('transactionquantity', '1');
    }

    function selectPartcode(input, key, partNumber) {
        input.value = partNumber;
        input.dispatchEvent(new Event('change', { bubbles: true, cancelable: false }));
        try {
            const cmpId = input.getAttribute('data-componentid');
            if (cmpId && typeof Ext !== 'undefined' && Ext.getCmp) {
                const cmp = Ext.getCmp(cmpId);
                if (cmp && cmp.setValue) cmp.setValue(partNumber);
            }
        } catch (e) {}
        input.style.backgroundColor = '#d4edda';
        input.style.transition      = 'background-color 0.3s';
        setTimeout(() => input.style.backgroundColor = '', 600);
        removeDropdown();
        setTimeout(() => autoFillQuantity(), 500);
        console.log(`[Partcode] "${key}" → "${partNumber}" (Quantity: 1)`);
    }

    // ═══════════════════════════════════════════════════════
    // EVENT LISTENER
    // ═══════════════════════════════════════════════════════
    document.addEventListener('input', (e) => {
        const input = e.target;
        if (input.name !== 'partcode') return;
        if (isEditorOpen) return;
        const val = input.value;
        if (val.length >= 1) {
            populateDropdown(input, val);
        } else {
            removeDropdown();
        }
    }, true);

    document.addEventListener('click', (e) => {
        if (isEditorOpen) return;
        if (activeDropdown && !activeDropdown.contains(e.target) && e.target !== activeInput) {
            removeDropdown();
        }
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' || e.key === 'Tab') {
            removeDropdown();
        }
    }, true);

    // ═══════════════════════════════════════════════════════
    // INITIALISIERUNG
    // ═══════════════════════════════════════════════════════
    function init() {
        injectEditorButton();
        setTimeout(injectEditorButton, 1000);
        setTimeout(injectEditorButton, 3000);
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    const observer = new MutationObserver(() => {
        injectEditorButton();
    });
    observer.observe(document.body, { childList: true, subtree: true });

    console.log('[Partcode Auto-Ersetzung v4.1] Geladen. Neue Einträge landen immer am Ende.');
})();
