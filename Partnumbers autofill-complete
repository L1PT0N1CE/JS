            const lbl2=mk('div','',`padding:3px 12px;background:#111820;color:#3a5a8a;font-size:10px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;`);lbl2.textContent=`EAM Catalog — ${fresh.length} Treffer`;liveWrap.appendChild(lbl2);
            fresh.forEach(r=>{
                const stk=parseInt(r.stock)||0;
                const it=mk('div','',`padding:7px 14px;cursor:pointer;border-bottom:1px solid #1e2a3a;display:flex;justify-content:space-between;align-items:center;`);
                it.innerHTML=`<span><span style="color:#6ba3e8;font-weight:700;font-family:monospace;">${r.part}</span><span style="color:#7a8aaa;margin-left:10px;font-size:12px;">${r.desc}</span></span><span style="display:flex;gap:6px;align-items:center;">${r.stock!==''?`<span style="padding:1px 7px;border-radius:3px;font-size:11px;font-weight:700;background:${stk>0?'#1a3a2a':'#3a1a1a'};color:${stk>0?'#4cce7a':'#e05555'};">${stk} Stk</span>`:''}<span style="padding:1px 5px;border-radius:3px;font-size:10px;background:#1a2a3a;color:#4a7ab5;font-weight:600;">EAM</span></span>`;
                it.addEventListener('mouseenter',()=>it.style.background='#232d3f');
                it.addEventListener('mouseleave',()=>it.style.background='');
                it.addEventListener('mousedown',ev=>{ev.stopImmediatePropagation();ev.preventDefault();selectPart(input,r.part);},true);
                liveWrap.appendChild(it);
            });
        },350);
