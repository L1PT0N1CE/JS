        const titleEl = Array.from(document.querySelectorAll('.x-title-text')).find(el =>
            el.textContent.trim() === 'Part Details & Planning'
        );
        if (!titleEl) return;
        if (titleEl.querySelector('#partcode-editor-btn')) return;

        const wrapper = document.createElement('span');
        wrapper.style.cssText = `
            display: inline-flex !important;
            align-items: center;
            white-space: nowrap;
        `;

        const originalText  = titleEl.textContent;
        titleEl.textContent = '';

        const textSpan          = document.createElement('span');
        textSpan.textContent    = originalText;
        textSpan.style.cssText  = 'display: inline;';
        wrapper.appendChild(textSpan);

        const btn    = document.createElement('span');
        btn.id       = 'partcode-editor-btn';
        btn.title    = 'Partcodes verwalten (' + partcodeMap.length + ' Einträge)';
        btn.style.cssText = `
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 18px;
            height: 18px;
            background: #1976d2;
            color: white;
            border-radius: 3px;
            cursor: pointer;
            font-size: 11px;
            margin-left: 6px;
            flex-shrink: 0;
            user-select: none;
            transition: background 0.2s;
        `;
        btn.innerHTML = '⚙️';
        btn.addEventListener('mouseenter', () => btn.style.background = '#1565c0');
        btn.addEventListener('mouseleave', () => btn.style.background = '#1976d2');
        btn.addEventListener('mousedown', (e) => {
            e.preventDefault();
            e.stopPropagation();
            removeDropdown();

            // ✅ Partcode-Textfeld leeren beim Öffnen
            const partcodeInput = document.querySelector('input[name="partcode"]');
            if (partcodeInput) {
                partcodeInput.value = '';
                partcodeInput.dispatchEvent(new Event('change', { bubbles: true }));
            }

            openEditor();
        });

        wrapper.appendChild(btn);
        titleEl.appendChild(wrapper);
    }

    // ═══════════════════════════════════════════════════════
    // EDITOR HILFSFUNKTIONEN
    // ═══════════════════════════════════════════════════════
    let currentEditorList = null;

    function editorRefreshList(container, scrollToBottom = false) {
        container.innerHTML = '';

        // ✅ Einträge MIT Key alphabetisch, leere Einträge ans Ende
        const withKey    = partcodeMap.filter(e => e.key.trim() !== '');
        const withoutKey = partcodeMap.filter(e => e.key.trim() === '');
        const sorted     = [
            ...withKey.sort((a, b) => a.key.localeCompare(b.key)),
            ...withoutKey
        ];

        if (sorted.length === 0) {
            container.innerHTML = '<div style="padding: 40px; text-align: center; color: #999;">Keine Einträge vorhanden</div>';
            return;
        }

        sorted.forEach((entry) => {
            const realIndex    = partcodeMap.indexOf(entry);
            const row          = document.createElement('div');
            row.dataset.index  = realIndex;
            row.style.cssText  = `
                display: flex;
                align-items: center;
                padding: 10px 20px;
                border-bottom: 1px solid #f0f0f0;
                gap: 8px;
            `;

            const keyInput  = createInlineInput(entry.key,  '130px', 'Alias', true);
            const partInput = createInlineInput(entry.part, '110px', 'Partnumber', false);
            const descInput = createInlineInput(entry.desc, '160px', 'Beschreibung', false);
            const saveBtn   = createIconButton('💾', '#28a745', 'Speichern');
            const delBtn    = createIconButton('🗑️', '#dc3545', 'Löschen');

            saveBtn.onclick = () => {
                const newKey  = keyInput.value.trim();
                const newPart = partInput.value.trim();
                const newDesc = descInput.value.trim();
                if (!newKey || !newPart) {
                    alert('Alias und Partnumber sind Pflicht!');
                    return;
                }
                const idx        = parseInt(row.dataset.index);
                partcodeMap[idx] = { key: newKey, part: newPart, desc: newDesc };
                savePartcodeMap(partcodeMap);
                editorRefreshList(container);
                showToast('✅ Gespeichert!');
            };

            delBtn.onclick = () => {
                if (confirm(`"${entry.key}" wirklich löschen?`)) {
                    const idx = parseInt(row.dataset.index);
                    partcodeMap.splice(idx, 1);
                    savePartcodeMap(partcodeMap);
                    editorRefreshList(container);
                    showToast('🗑️ Gelöscht!');
                }
            };

            // ✅ Neuer leerer Eintrag visuell hervorheben
            if (entry.key.trim() === '' && entry.part.trim() === '') {
                row.style.background      = '#fffde7';
                keyInput.style.borderColor = '#ffc107';
            }

            row.appendChild(keyInput);
            row.appendChild(partInput);
            row.appendChild(descInput);
            row.appendChild(saveBtn);
            row.appendChild(delBtn);
            container.appendChild(row);
        });

        if (scrollToBottom) {
            requestAnimationFrame(() => {
                container.scrollTop = container.scrollHeight;
            });
        }
    }

    function editorSaveAll(container) {
        const rows   = container.querySelectorAll('div[data-index]');
        const newMap = [];
        let errorFound = false;

        rows.forEach(row => {
            const inputs  = row.querySelectorAll('input');
            const newKey  = inputs[0].value.trim();
            const newPart = inputs[1].value.trim();
            const newDesc = inputs[2].value.trim();

            if (!newKey || !newPart) {
                inputs[0].style.borderColor = !newKey  ? '#dc3545' : '#ddd';
                inputs[1].style.borderColor = !newPart ? '#dc3545' : '#ddd';
                errorFound = true;
                return;
            }

            newMap.push({ key: newKey, part: newPart, desc: newDesc });
        });

        if (errorFound) {
            showToast('⚠️ Alias & Partnumber dürfen nicht leer sein!');
            return;
        }

        partcodeMap = newMap;
        savePartcodeMap(partcodeMap);
        editorRefreshList(container);
        showToast('✅ Alle Einträge gespeichert!');
    }

    function editorAddNewEntry() {
        if (!currentEditorList) return;
        // ✅ Leeren Eintrag pushen, landet automatisch am Ende der sortierten Liste
        partcodeMap.push({ key: '', part: '', desc: '' });
        editorRefreshList(currentEditorList, true);

        setTimeout(() => {
            const inputs       = currentEditorList.querySelectorAll('input');
            const lastKeyInput = inputs[inputs.length - 3];
            if (lastKeyInput) {
                lastKeyInput.focus();
                lastKeyInput.select();
                lastKeyInput.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }
        }, 50);
    }

