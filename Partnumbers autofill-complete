        function switchTab(id){
            activeTab=id;
            [tabDB,tabEAM].forEach(t=>{const a=t.dataset.tab===id;t.style.color=a?'#c8d8f8':'#6a7a9a';t.style.borderBottom=a?'2px solid #4a8ae8':'2px solid transparent';});
            body.innerHTML='';
