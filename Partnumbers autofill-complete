    // ═══════════════════════════════════════════════════════
    function injectEditorButton() {
        const acceptedTitles = ['Part Details & Planning', 'Teiledetails und Planung'];
        const titleEl = Array.from(document.querySelectorAll('.x-title-text')).find(el => acceptedTitles.includes(el.textContent.trim()));
        if (!titleEl || titleEl.querySelector('#partcode-editor-btn')) return;

        const wrapper = document.createElement('span');
        wrapper.style.cssText = 'display:inline-flex !important; align-items:center; white-space:nowrap;';
        const orig = titleEl.textContent;
        titleEl.textContent = '';
        const textSpan = document.createElement('span');
        textSpan.textContent = orig;
        wrapper.appendChild(textSpan);

        const btn = document.createElement('span');
        btn.id = 'partcode-editor-btn';
        btn.title = `Partcodes verwalten (${partcodeMap.length} Einträge)`;
        btn.style.cssText = 'display:inline-flex; align-items:center; justify-content:center; width:18px; height:18px; background:#1976d2; color:white; border-radius:3px; cursor:pointer; font-size:11px; margin-left:6px; user-select:none;';
        btn.innerHTML = '⚙️';
        btn.addEventListener('mouseenter', () => btn.style.background = '#1565c0');
        btn.addEventListener('mouseleave', () => btn.style.background = '#1976d2');
        btn.addEventListener('mousedown', (e) => {
            e.preventDefault(); e.stopPropagation(); removeDropdown();
            const pi = document.querySelector('input[name="partcode"]');
            if (pi) { pi.value = ''; pi.dispatchEvent(new Event('change', { bubbles: true })); }
            openEditor();
        });
        wrapper.appendChild(btn);
        titleEl.appendChild(wrapper);
    }

    // ── Editor (identisch v4, kompakt) ──────────────────────────────────────
    let currentEditorList = null;

    function editorRefreshList(container, scrollToBottom = false) {
        container.innerHTML = '';
        const sorted = [
            ...partcodeMap.filter(e => e.key.trim()).sort((a,b) => a.key.localeCompare(b.key)),
            ...partcodeMap.filter(e => !e.key.trim())
        ];
        if (!sorted.length) { container.innerHTML = '<div style="padding:40px; text-align:center; color:#999;">Keine Einträge</div>'; return; }
        sorted.forEach(entry => {
            const realIdx = partcodeMap.indexOf(entry);
            const row = document.createElement('div');
            row.dataset.index = realIdx;
            row.style.cssText = 'display:flex; align-items:center; padding:10px 20px; border-bottom:1px solid #f0f0f0; gap:8px;';
            if (!entry.key.trim() && !entry.part.trim()) { row.style.background = '#fffde7'; }
            const ki = mkInput(entry.key, '130px', 'Alias', true);
            const pi = mkInput(entry.part, '110px', 'Partnumber', false);
            const di = mkInput(entry.desc, '160px', 'Beschreibung', false);
            const sv = mkIconBtn('💾','#28a745','Speichern');
            const dl = mkIconBtn('🗑️','#dc3545','Löschen');
            sv.onclick = () => {
                const nk = ki.value.trim(), np = pi.value.trim(), nd = di.value.trim();
                if (!nk || !np) { alert('Alias & Partnumber sind Pflicht!'); return; }
                partcodeMap[parseInt(row.dataset.index)] = { key: nk, part: np, desc: nd };
                savePartcodeMap(partcodeMap); editorRefreshList(container); showToast('✅ Gespeichert!');
            };
            dl.onclick = () => {
                if (confirm(`"${entry.key}" löschen?`)) {
                    partcodeMap.splice(parseInt(row.dataset.index), 1);
                    savePartcodeMap(partcodeMap); editorRefreshList(container); showToast('🗑️ Gelöscht!');
                }
            };
            [ki,pi,di,sv,dl].forEach(el => row.appendChild(el));
            container.appendChild(row);
        });
        if (scrollToBottom) requestAnimationFrame(() => { container.scrollTop = container.scrollHeight; });
    }

    function openEditor() {
        if (isEditorOpen) return; isEditorOpen = true;
        document.getElementById('partcode-editor-overlay')?.remove();
        const overlay = document.createElement('div');
        overlay.id = 'partcode-editor-overlay';
        overlay.style.cssText = 'position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:1000000; display:flex; justify-content:center; align-items:center; font-family:Arial,sans-serif;';
        const panel = document.createElement('div');
        panel.style.cssText = 'background:#fff; border-radius:8px; width:650px; max-height:85vh; display:flex; flex-direction:column; box-shadow:0 10px 40px rgba(0,0,0,.3);';

        const header = document.createElement('div');
        header.style.cssText = 'padding:16px 20px; border-bottom:1px solid #e0e0e0; display:flex; justify-content:space-between; align-items:center;';
        header.innerHTML = `<h2 style="margin:0; font-size:18px; color:#333;">🔧 Partnumber Editor</h2><span style="color:#666; font-size:12px;">${partcodeMap.length} Einträge</span>`;

        const toolbar = document.createElement('div');
        toolbar.style.cssText = 'padding:12px 20px; background:#f8f9fa; border-bottom:1px solid #e0e0e0; display:flex; gap:8px; flex-wrap:wrap;';
        const addBtn     = mkToolBtn('➕ New',      '#28a745');
        const saveAllBtn = mkToolBtn('💾 Save All', '#1976d2');
        const importBtn  = mkToolBtn('📥 Import',   '#6c757d');
        const exportBtn  = mkToolBtn('📤 Export',   '#6c757d');
        const resetBtn   = mkToolBtn('🔄 Reset',    '#dc3545');
        addBtn.onclick = () => {
            partcodeMap.push({ key: '', part: '', desc: '' });
            editorRefreshList(listContainer, true);
            setTimeout(() => {
                const inputs = listContainer.querySelectorAll('input');
                const last = inputs[inputs.length - 3];
                if (last) { last.focus(); last.select(); last.scrollIntoView({ behavior:'smooth', block:'nearest' }); }
            }, 50);
        };
        saveAllBtn.onclick = () => {
            const rows = listContainer.querySelectorAll('div[data-index]');
            const newMap = []; let err = false;
            rows.forEach(r => {
                const [k,p,d] = Array.from(r.querySelectorAll('input')).map(i => i.value.trim());
                if (!k || !p) { err = true; return; }
                newMap.push({ key: k, part: p, desc: d });
            });
            if (err) { showToast('⚠️ Alias & Partnumber dürfen nicht leer sein!'); return; }
            partcodeMap = newMap; savePartcodeMap(partcodeMap); editorRefreshList(listContainer); showToast('✅ Alle gespeichert!');
        };
        importBtn.onclick = importJSON; exportBtn.onclick = exportJSON;
        resetBtn.onclick = () => {
            if (confirm('Alles zurücksetzen?')) {
                localStorage.removeItem(STORAGE_KEY);
                partcodeMap = JSON.parse(JSON.stringify(defaultPartcodeMap));
                editorRefreshList(listContainer);
            }
        };
        [addBtn, saveAllBtn, importBtn, exportBtn, resetBtn].forEach(b => toolbar.appendChild(b));

        const listContainer = document.createElement('div');
        listContainer.style.cssText = 'overflow-y:auto; flex:1;';
        currentEditorList = listContainer;

        const footer = document.createElement('div');
        footer.style.cssText = 'padding:12px 20px; border-top:1px solid #e0e0e0; display:flex; justify-content:space-between; align-items:center; background:#f8f9fa; border-radius:0 0 8px 8px;';
        const hint = document.createElement('span');
        hint.style.cssText = 'color:#666; font-size:12px; display:flex; align-items:center; gap:8px;';
        hint.innerHTML = `VERGISS NICHT ZU SPEICHERN DU HOND
            <a href="https://amazondeu-my.sharepoint.com/:x:/r/personal/kanataza_amazon_de/Documents/Spareparts%20by%20Azad%20Kanat%20%26%20Co.xlsx?d=w6898e9f8051f4f8fb18dda1fa38c271b&csf=1&web=1&e=bWpnWq"
               target="_blank" style="color:#1976d2; text-decoration:none; font-size:12px; font-weight:600; padding:2px 7px; border:1px solid #1976d2; border-radius:3px; background:#e3f2fd; white-space:nowrap;">📋 Azad's Sparepartliste</a>`;
        const closeBtn = document.createElement('button');
        closeBtn.textContent = 'Schließen';
        closeBtn.style.cssText = 'padding:8px 20px; background:#1976d2; color:white; border:none; border-radius:4px; cursor:pointer; font-size:14px;';
        closeBtn.onclick = () => { isEditorOpen = false; currentEditorList = null; overlay.remove(); };
        footer.appendChild(hint); footer.appendChild(closeBtn);

        [header, toolbar, listContainer, footer].forEach(el => panel.appendChild(el));
        overlay.appendChild(panel);
        document.body.appendChild(overlay);
        editorRefreshList(listContainer);
    }

    // ── Mini-Helpers ─────────────────────────────────────────────────────────
    function mkToolBtn(text, color) {
        const b = document.createElement('button');
        b.textContent = text;
        b.style.cssText = `padding:6px 12px; background:${color}; color:white; border:none; border-radius:4px; cursor:pointer; font-size:13px; font-weight:500;`;
        return b;
    }
    function mkIconBtn(icon, color, title) {
        const b = document.createElement('button');
        b.textContent = icon; b.title = title;
        b.style.cssText = `width:32px; height:32px; border:none; background:${color}; color:white; border-radius:4px; cursor:pointer; font-size:14px; display:flex; align-items:center; justify-content:center; flex-shrink:0;`;
        return b;
    }
    function mkInput(value, width, placeholder, forceLower) {
        const inp = document.createElement('input');
        inp.value = value; inp.placeholder = placeholder;
        inp.style.cssText = `width:${width}; padding:6px 8px; border:1px solid #ddd; border-radius:4px; font-size:13px; font-family:monospace; flex-shrink:0; ${forceLower ? 'text-transform:lowercase;' : ''}`;
        if (forceLower) inp.addEventListener('input', () => { const p = inp.selectionStart; inp.value = inp.value.toLowerCase(); inp.setSelectionRange(p,p); });
        inp.addEventListener('mousedown', e => e.stopPropagation(), true);
        inp.addEventListener('click',     e => e.stopPropagation(), true);
        return inp;
    }
    function exportJSON() {
        const blob = new Blob([JSON.stringify(partcodeMap, null, 2)], { type: 'application/json' });
        const a = Object.assign(document.createElement('a'), { href: URL.createObjectURL(blob), download: 'partcodes_export.json' });
        a.click(); URL.revokeObjectURL(a.href); showToast('📤 Exportiert!');
    }
    function importJSON() {
        const inp = Object.assign(document.createElement('input'), { type: 'file', accept: '.json' });
        inp.onchange = e => {
            const file = e.target.files[0]; if (!file) return;
            const r = new FileReader();
            r.onload = ev => {
                try {
                    let imported = JSON.parse(ev.target.result);
                    if (!Array.isArray(imported)) imported = Object.entries(imported).map(([k,v]) => ({ key:k, part:v.part, desc:v.desc||'' }));
                    if (confirm(`${imported.length} Einträge importieren?`)) {
                        partcodeMap.push(...imported); savePartcodeMap(partcodeMap);
                        if (currentEditorList) editorRefreshList(currentEditorList);
                        showToast('📥 Import ok!');
                    }
                } catch(err) { alert('Fehler: ' + err.message); }
            };
            r.readAsText(file);
        };
        inp.click();
    }
    function showToast(msg) {
        const t = document.createElement('div');
        t.textContent = msg;
        t.style.cssText = 'position:fixed; bottom:30px; left:50%; transform:translateX(-50%); background:#333; color:white; padding:12px 24px; border-radius:6px; font-size:14px; z-index:1000001;';
        document.body.appendChild(t);
        setTimeout(() => { t.style.transition = 'opacity .3s'; t.style.opacity = '0'; setTimeout(() => t.remove(), 300); }, 2000);
    }

    // ═══════════════════════════════════════════════════════
    // EVENT LISTENER
    // ═══════════════════════════════════════════════════════
    document.addEventListener('input', (e) => {
        const input = e.target;
        if (input.name !== 'partcode' || isEditorOpen) return;
        if (input.value.length >= 1) populateDropdown(input, input.value);
        else removeDropdown();
    }, true);

    document.addEventListener('click', (e) => {
        if (isEditorOpen) return;
        if (activeDropdown && !activeDropdown.contains(e.target) && e.target !== activeInput) removeDropdown();
    });

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' || e.key === 'Tab') removeDropdown();
    }, true);

    // ═══════════════════════════════════════════════════════
    // INIT
    // ═══════════════════════════════════════════════════════
    const style = document.createElement('style');
    style.textContent = '@keyframes slideUp { from{transform:translateX(-50%) translateY(20px);opacity:0} to{transform:translateX(-50%) translateY(0);opacity:1} }';
    document.head.appendChild(style);

    function init() { injectEditorButton(); setTimeout(injectEditorButton, 1000); setTimeout(injectEditorButton, 3000); }
    document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', init) : init();
    new MutationObserver(() => injectEditorButton()).observe(document.body, { childList: true, subtree: true });

    console.log('[Partcode v5.0] Bereit — lokal + EAM Live-Suche aktiv.');
})();
