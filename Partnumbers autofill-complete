    function loadPartcodeMap() {
        try {
            const stored = localStorage.getItem(STORAGE_KEY);
            if (stored) return JSON.parse(stored);
        } catch (e) {}
        return JSON.parse(JSON.stringify(defaultPartcodeMap));
    }
    function savePartcodeMap(map) {
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(map)); return true; } catch(e) { return false; }
