    // ═══════════════════════════════════════════════════════
    // EAM SESSION (für Live-Suche)
    // ═══════════════════════════════════════════════════════
    function getEamSession() {
        // 1) aus iframe src (zuverlässigste Quelle)
        const iframe = document.querySelector('iframe[src*="eamid="]');
        if (iframe) {
            try {
                const p = new URL(iframe.src).searchParams;
                const eamid = p.get('eamid'), tenant = p.get('tenant');
                if (eamid) return { eamid, tenant: tenant || 'AMAZONRMEEU_PRD' };
            } catch(e) {}
        }
        // 2) aus EAM SessionStorage namespace
        try {
            const sess = window.EAM?.SessionStorage;
            if (sess?.eamid) return { eamid: sess.eamid, tenant: sess.tenant || 'AMAZONRMEEU_PRD' };
        } catch(e) {}
        // 3) aus gAppData (Start Center)
        try {
            const ip = window.gAppData?.initparams || '';
            const m = ip.match(/eamid=([^&]+)/);
            if (m) return { eamid: m[1], tenant: 'AMAZONRMEEU_PRD' };
        } catch(e) {}
        return null;
    }

    function getBaseUrl() {
        return `https://${window.location.hostname}/web/base/`;
    }

    // ═══════════════════════════════════════════════════════
    // LIVE EAM SUCHE (SSPART.xmlhttp)
    // ═══════════════════════════════════════════════════════
    let _liveDebounceTimer = null;
    let _liveAbort = null;

    async function searchEAMLive(query) {
        const sess = getEamSession();
        if (!sess) return [];

        if (_liveAbort) _liveAbort.abort();
        _liveAbort = new AbortController();

        const q = query.trim();
        // MADDON_FILTER: partcode CONTAINS q  OR  partdescription CONTAINS q
        const params = new URLSearchParams({
            GRID_ID:                        '80',
            GRID_NAME:                      'SSPART',
            DATASPY_ID:                     '101466',
            USER_FUNCTION_NAME:             'SSPART',
            SYSTEM_FUNCTION_NAME:           'SSPART',
            CURRENT_TAB_NAME:               'LST',
            COMPONENT_INFO_TYPE:            'DATA_ONLY',
            FORCE_REQUERY:                  'YES',
            MAX_ROWS:                       '30',
            NUMBER_OF_ROWS_FIRST_RETURNED:  '30',
            eamid:                          sess.eamid,
            tenant:                         sess.tenant,
            // Filter 1: partcode CONTAINS q (OR)
            MADDON_FILTER_ALIAS_NAME_1:     'partcode',
            MADDON_FILTER_OPERATOR_1:       'CONTAINS',
            MADDON_FILTER_VALUE_1:          q,
            MADDON_FILTER_SEQNUM_1:         '1',
            MADDON_FILTER_JOINER_1:         'OR',
            MADDON_LPAREN_1:                'true',
            MADDON_RPAREN_1:                'false',
            // Filter 2: partdescription CONTAINS q (end of OR group)
            MADDON_FILTER_ALIAS_NAME_2:     'partdescription',
            MADDON_FILTER_OPERATOR_2:       'CONTAINS',
            MADDON_FILTER_VALUE_2:          q,
            MADDON_FILTER_SEQNUM_2:         '2',
            MADDON_FILTER_JOINER_2:         'AND',
            MADDON_LPAREN_2:                'false',
            MADDON_RPAREN_2:                'true',
        });

        try {
            const resp = await fetch(getBaseUrl() + 'SSPART.xmlhttp', {
                method:      'POST',
                headers:     { 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8', 'X-Requested-With': 'XMLHttpRequest' },
                body:        params.toString(),
                credentials: 'include',
                signal:      _liveAbort.signal
            });
            const text = await resp.text();
            const json = JSON.parse(text);
            const meta = json?.pageData?.grid?.GRIDRESULT?.GRID?.METADATA?.COLUMN || [];
            const data = json?.pageData?.grid?.GRIDRESULT?.GRID?.DATA || [];

            // Spalten-Index einmalig aufbauen
            const colIdx = {};
            (Array.isArray(meta) ? meta : [meta]).forEach((col, i) => {
                const name = col?.ALIAS_NAME || col?.COLUMN_NAME || '';
                colIdx[name.toLowerCase()] = i;
            });

            return data.map(row => {
                const arr = Array.isArray(row) ? row : Object.values(row);
                const get = (name) => arr[colIdx[name.toLowerCase()]] ?? '';
                return {
                    part:  get('partcode'),
                    desc:  get('partdescription'),
                    stock: get('par_currbal') || get('instock') || '',
                    // Foto-URL wenn vorhanden (braucht documentcode Feld)
                    imgCode: get('documentcode') || get('imagecode') || '',
                };
            }).filter(r => r.part);
        } catch(e) {
            if (e.name !== 'AbortError') console.warn('[Partcode Live] Fehler:', e);
            return [];
        }
    }

    function getPartImgUrl(docCode) {
        if (!docCode) return null;
        const sess = getEamSession();
        if (!sess) return null;
        // EAM Dokument-Viewer — selbes Prinzip wie APM Master
        return `${getBaseUrl()}VIEWUDOC?documentcode=${encodeURIComponent(docCode)}&keepcontenttype=true&eamid=${sess.eamid}&tenant=${sess.tenant}`;
    }

    // ═══════════════════════════════════════════════════════
    // DROPDOWN
    // ═══════════════════════════════════════════════════════
    let activeDropdown = null;
    let activeInput    = null;
    let isEditorOpen   = false;

    function createDropdown(input) {
        removeDropdown();
        const rect     = input.getBoundingClientRect();
        const dropdown = document.createElement('div');
        dropdown.id    = 'partcode-autocomplete';
        dropdown.style.cssText = `
            position:fixed; top:${rect.bottom}px; left:${rect.left}px;
            width:${Math.max(rect.width, 480)}px; max-height:360px;
            overflow-y:auto; background:#fff; border:1px solid #ccc;
            border-top:none; border-radius:0 0 4px 4px;
            box-shadow:0 4px 12px rgba(0,0,0,.18);
            z-index:999999; font-family:Arial,sans-serif; font-size:13px;
        `;
        activeDropdown = dropdown;
        activeInput    = input;
        document.body.appendChild(dropdown);
        return dropdown;
    }

    function removeDropdown() {
        if (activeDropdown) { activeDropdown.remove(); activeDropdown = null; activeInput = null; }
        clearTimeout(_liveDebounceTimer);
    }

    function makeSectionLabel(text) {
        const d = document.createElement('div');
        d.style.cssText = 'padding:4px 12px; background:#f0f4ff; color:#1565c0; font-size:11px; font-weight:600; letter-spacing:.5px; text-transform:uppercase; user-select:none;';
        d.textContent = text;
        return d;
    }

    function makeItem(part, desc, stock, imgCode, isLive) {
        const item = document.createElement('div');
        item.className = 'partcode-item';
        item.dataset.part = part;
        item.style.cssText = 'padding:7px 12px; cursor:pointer; border-bottom:1px solid #eee; display:flex; justify-content:space-between; align-items:center; gap:8px; user-select:none;';
        item.addEventListener('mouseenter', () => item.style.backgroundColor = '#e3f2fd');
        item.addEventListener('mouseleave', () => item.style.backgroundColor = '#fff');
        item.addEventListener('mousedown', (e) => {
            e.stopImmediatePropagation(); e.preventDefault();
            if (activeInput) selectPartcode(activeInput, part);
        }, true);

        const left = document.createElement('span');
        left.innerHTML = isLive
            ? `<span style="color:#1976d2; font-weight:600;">${part}</span> <span style="color:#555; margin-left:6px;">${desc}</span>`
            : `<strong style="color:#1976d2;">${part}</strong> <span style="color:#666; margin-left:6px;">${desc}</span>`;

        const right = document.createElement('span');
        right.style.cssText = 'display:flex; align-items:center; gap:8px; flex-shrink:0;';
        if (stock !== '') {
            const s = document.createElement('span');
            s.style.cssText = `padding:1px 6px; border-radius:3px; font-size:11px; font-weight:600; background:${Number(stock) > 0 ? '#e8f5e9' : '#fce4ec'}; color:${Number(stock) > 0 ? '#2e7d32' : '#c62828'};`;
            s.textContent = `Lager: ${stock}`;
            right.appendChild(s);
        }
        if (imgCode) {
            const img = document.createElement('img');
            img.src = getPartImgUrl(imgCode);
            img.style.cssText = 'width:32px; height:32px; object-fit:contain; border:1px solid #ddd; border-radius:3px;';
            img.onerror = () => img.remove();
            right.appendChild(img);
        }

        item.appendChild(left);
        item.appendChild(right);
        return item;
    }

    async function populateDropdown(input, query) {
        const dropdown = createDropdown(input);
        const q = query.toLowerCase().trim();

        // 1) Lokale Treffer sofort anzeigen
        const localMatches = partcodeMap.filter(e =>
            e.key.toLowerCase().includes(q) || e.desc.toLowerCase().includes(q) || e.part.toLowerCase().includes(q)
        );

        if (localMatches.length > 0) {
            dropdown.appendChild(makeSectionLabel('Meine Datenbank'));
            localMatches.forEach(e => dropdown.appendChild(makeItem(e.part, `${e.key} — ${e.desc}`, '', '', false)));
        }

        // Live-Suche-Platzhalter
        const liveSection = document.createElement('div');
        liveSection.innerHTML = '<div style="padding:8px 12px; color:#888; font-style:italic; font-size:12px;">⏳ EAM wird durchsucht…</div>';
        dropdown.appendChild(liveSection);

        // 2) Debounced live search
        clearTimeout(_liveDebounceTimer);
        _liveDebounceTimer = setTimeout(async () => {
            if (!activeDropdown) return;
            const liveResults = await searchEAMLive(q);

            liveSection.innerHTML = '';
            if (liveResults.length === 0) {
                liveSection.innerHTML = '<div style="padding:6px 12px; color:#aaa; font-size:12px; font-style:italic;">Keine weiteren EAM-Treffer.</div>';
                return;
            }

            // Duplikate mit lokaler DB rausfiltern
            const localParts = new Set(localMatches.map(e => e.part));
            const newOnes    = liveResults.filter(r => !localParts.has(r.part));

            if (newOnes.length > 0) {
                liveSection.appendChild(makeSectionLabel('EAM Parts Catalog (live)'));
                newOnes.forEach(r => liveSection.appendChild(makeItem(r.part, r.desc, r.stock, r.imgCode, true)));
            } else {
                liveSection.innerHTML = '<div style="padding:6px 12px; color:#aaa; font-size:12px; font-style:italic;">Alle EAM-Treffer schon in lokaler DB.</div>';
            }
        }, 350);
    }

    // ═══════════════════════════════════════════════════════
    // PART AUSWÄHLEN
    // ═══════════════════════════════════════════════════════
    function selectPartcode(input, partNumber) {
        input.value = partNumber;
        input.dispatchEvent(new Event('change', { bubbles: true }));
        try {
            const cmpId = input.getAttribute('data-componentid');
            if (cmpId && typeof Ext !== 'undefined') {
                const cmp = Ext.getCmp(cmpId);
                if (cmp?.setValue) cmp.setValue(partNumber);
            }
        } catch(e) {}
        input.style.backgroundColor = '#d4edda';
        input.style.transition = 'background-color 0.3s';
        setTimeout(() => input.style.backgroundColor = '', 600);
        removeDropdown();
        setTimeout(() => setExtFieldValue('transactionquantity', '1'), 500);
    }

    // ═══════════════════════════════════════════════════════
    // EXT HILFSFUNKTIONEN
    // ═══════════════════════════════════════════════════════
    function getExtComponent(name) {
        if (typeof Ext === 'undefined' || !Ext.ComponentQuery) return null;
        const cmps = Ext.ComponentQuery.query(`[name="${name}"]`);
        return cmps?.length ? cmps[0] : null;
    }
    function setExtFieldValue(name, value) {
        const cmp = getExtComponent(name);
        if (cmp?.setValue) { cmp.setValue(value); cmp.fireEvent?.('change', cmp, value); return true; }
        const input = document.querySelector(`input[name="${name}"]`);
        if (input) { input.value = value; input.dispatchEvent(new Event('change', { bubbles: true })); }
        return !!input;
    }

