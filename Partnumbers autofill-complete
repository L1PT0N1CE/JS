    // TAB: MEINE DB
    function buildDBTab(container){
        const tb=mk('div','',`padding:10px 14px;background:#1a2030;border-bottom:1px solid #2a3447;display:flex;gap:8px;flex-wrap:wrap;flex-shrink:0;`);
        const addBtn=dBtn('➕ New','#1d6b38','#27964e');
        const svAll=dBtn('💾 Save All','#1a3a6a','#1e4d8a');
        const imp=dBtn('📥 Import','#2a3040','#3a4050');
        const exp=dBtn('📤 Export','#2a3040','#3a4050');
        const rst=dBtn('🔄 Reset','#5a1a1a','#7a2828');
        [addBtn,svAll,imp,exp,rst].forEach(b=>tb.appendChild(b));
        const list=mk('div','',`overflow-y:auto;flex:1;background:#1a2030;`);
        renderDB(list);
        container.appendChild(tb);container.appendChild(list);

        addBtn.onclick=()=>{
            partcodeMap.push({key:'',part:'',desc:''});renderDB(list,true);
            setTimeout(()=>{const ins=list.querySelectorAll('input');const last=ins[ins.length-3];if(last){last.focus();last.select();last.scrollIntoView({behavior:'smooth',block:'nearest'});}},60);
        };
        svAll.onclick=()=>{
            const rows=list.querySelectorAll('div[data-index]');const nm=[];let err=false;
            rows.forEach(r=>{const [k,p,d]=Array.from(r.querySelectorAll('input')).map(i=>i.value.trim());if(!k||!p){err=true;return;}nm.push({key:k,part:p,desc:d});});
            if(err){toast('⚠️ Alias & Partnumber dürfen nicht leer sein!');return;}
            partcodeMap=nm;saveMap(partcodeMap);renderDB(list);toast('✅ Alle gespeichert!');
        };
        imp.onclick=doImport;exp.onclick=doExport;
        rst.onclick=()=>{if(confirm('Alles zurücksetzen?')){localStorage.removeItem(STORAGE_KEY);partcodeMap=JSON.parse(JSON.stringify(DEFAULT_MAP));renderDB(list);}};
    }

    function renderDB(container,scrollBottom=false){
        container.innerHTML='';
        const sorted=[...partcodeMap.filter(e=>e.key.trim()).sort((a,b)=>a.key.localeCompare(b.key)),...partcodeMap.filter(e=>!e.key.trim())];
        if(!sorted.length){const d=mk('div','',`padding:40px;text-align:center;color:#334;`);d.textContent='Keine Einträge';container.appendChild(d);return;}
        sorted.forEach(entry=>{
            const ri=partcodeMap.indexOf(entry);
            const isEmpty=!entry.key.trim()&&!entry.part.trim();
            const row=mk('div','',`display:flex;align-items:center;padding:7px 14px;border-bottom:1px solid #1e2a3a;gap:8px;background:${isEmpty?'#1a2518':'#1e2434'};transition:background .1s;`);
            row.dataset.index=ri;
            row.addEventListener('mouseenter',()=>{if(!isEmpty)row.style.background='#252e40';});
            row.addEventListener('mouseleave',()=>{if(!isEmpty)row.style.background='#1e2434';});
            const ki=dkInp(entry.key,'130px','Alias',true);
            const pi=dkInp(entry.part,'110px','Partnumber',false);
            const di=dkInp(entry.desc,'160px','Beschreibung',false);
            const sv=iBtn('💾','#1d6b38','#27964e','Speichern');
            const dl=iBtn('🗑️','#7b1f1f','#a52828','Löschen');
            sv.onclick=()=>{
                const nk=ki.value.trim(),np=pi.value.trim(),nd=di.value.trim();
                if(!nk||!np){toast('⚠️ Pflichtfelder!');return;}
                partcodeMap[parseInt(row.dataset.index)]={key:nk,part:np,desc:nd};saveMap(partcodeMap);renderDB(container);toast('✅ Gespeichert!');
            };
            dl.onclick=()=>{if(confirm(`"${entry.key}" löschen?`)){partcodeMap.splice(parseInt(row.dataset.index),1);saveMap(partcodeMap);renderDB(container);toast('🗑️ Gelöscht!');}};
            [ki,pi,di,sv,dl].forEach(e=>row.appendChild(e));container.appendChild(row);
        });
        if(scrollBottom)requestAnimationFrame(()=>{container.scrollTop=container.scrollHeight;});
    }

    // TAB: EAM SUCHEN — getrennte Felder wie APM Master
    function buildEAMTab(container){
