        }
        const tabDB=mkTab('db','📋 Meine DB');
        const tabEAM=mkTab('eam','🔍 EAM Suchen');
        tabBar.appendChild(tabDB);tabBar.appendChild(tabEAM);

        const body=mk('div','',`flex:1;overflow:hidden;display:flex;flex-direction:column;min-height:0;`);

