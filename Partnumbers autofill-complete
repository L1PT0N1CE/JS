        hint.innerHTML='VERGISS NICHT ZU SPEICHERN DU HOND <a href="https://amazondeu-my.sharepoint.com/:x:/r/personal/kanataza_amazon_de/Documents/Spareparts%20by%20Azad%20Kanat%20%26%20Co.xlsx?d=w6898e9f8051f4f8fb18dda1fa38c271b&csf=1&web=1&e=bWpnWq" target="_blank" style="color:#5a9ae8;text-decoration:none;padding:2px 8px;border:1px solid #2a4a7a;border-radius:3px;background:#0f1e35;font-weight:600;white-space:nowrap;">📋 Azad\'s Liste</a>';
        footer.appendChild(hint);

        panel.appendChild(hdr);panel.appendChild(tabBar);panel.appendChild(body);panel.appendChild(footer);
        overlay.appendChild(panel);document.body.appendChild(overlay);

