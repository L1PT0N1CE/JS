                    const title   = tr.dataset.title || '';
                    const text    = btn.dataset.tpl === 'empfang'
                        ? 'Hello,\nthe RME team has received your ticket and will process your request as soon as possible.\nBest regards.'
                        : getResponseTextFromTitle(title);
                    openCommOverlay(shortId, title);
                    setTimeout(() => {
                        const co = document.getElementById('sim-tab-co');
                        if (co) co.click();
                        const ta = document.getElementById('sim-reply-text');
                        if (ta) { ta.value = text; ta.focus(); }
