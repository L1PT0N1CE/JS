    // ── Assign to Me ─────────────────────────────────────────────────────────────

    function getMyIdentity() {
        let stored = localStorage.getItem('sim_my_identity');
        if (stored) return stored;
        // Auto-detect from EAM login keys
        const alias = localStorage.getItem('wf4_defaultEmployee') || localStorage.getItem('apmUsername') || localStorage.getItem('bl_username');
        if (alias) {
            stored = 'kerberos:' + alias + '@ANT.AMAZON.COM';
            localStorage.setItem('sim_my_identity', stored);
            return stored;
        }
        // Fallback: prompt once
        const inp = prompt('Gib deinen Amazon-Login ein (z.B. kanataza):');
        if (!inp) return null;
        stored = 'kerberos:' + inp.trim().toLowerCase() + '@ANT.AMAZON.COM';
        localStorage.setItem('sim_my_identity', stored);
        return stored;
    }

    function attachAssignBtn(shortId) {
        const btn = document.getElementById('sim-assign-me-btn');
        if (!btn) return;
        btn.addEventListener('click', () => {
            const issueId = window._simCurrentIssueId;
            const identity = getMyIdentity();
            if (!issueId || !identity) return;
            btn.disabled = true;
            btn.textContent = '…';
            gqlPost({
                operationName: 'assignIssue',
                variables: { issueId, assignee: identity },
                query: `mutation assignIssue($issueId: String!, $assignee: String!) {
  assignIssue(issueId: $issueId, assignee: $assignee) {
    id
    assignee { id name protocol __typename }
    __typename
  }
}`
            }, (err, res) => {
                btn.disabled = false;
                if (err || !res || res.status !== 200) {
                    btn.textContent = '✗'; btn.style.borderColor = '#c00'; btn.style.color = '#c00';
                    setTimeout(() => { btn.textContent = '👤 Assign to Me'; btn.style.borderColor = ''; btn.style.color = ''; }, 2500);
                    return;
                }
                let j; try { j = JSON.parse(res.responseText); } catch(e) {}
                const ok = j && j.data && j.data.assignIssue && !(j.errors && j.errors.length);
                if (ok) {
                    btn.textContent = '✓ Assigned!'; btn.style.borderColor = '#2e7d32'; btn.style.color = '#2e7d32';
                    setTimeout(() => loadIssueOverview(shortId), 800);
                } else {
                    const msg = j && j.errors && j.errors[0] && j.errors[0].message;
                    btn.textContent = '✗ ' + (msg || 'Fehler'); btn.style.borderColor = '#c00'; btn.style.color = '#c00';
                    setTimeout(() => { btn.textContent = '👤 Assign to Me'; btn.style.borderColor = ''; btn.style.color = ''; }, 3000);
                }
            });
        });
    }

    // ── Übersicht ─────────────────────────────────────────────────────────────────

    function loadIssueOverview(shortId) {
        const pane = document.getElementById('sim-pane-overview');
        if (!pane) return;
        gqlPost({ operationName:'getIssueOverview', variables:{id:shortId},
            query:`query getIssueOverview($id: String!) {
  issue(id: $id) { id shortId title status severity createDate lastUpdatedDate description assignee { name } extensions { tt { assignedGroup } } }
}` }, (err,res) => {
            if (!pane.isConnected) return;
            if (err) { pane.innerHTML=errBox('Netzwerkfehler'); return; }
            let j; try { j=JSON.parse(res.responseText); } catch(e) { pane.innerHTML=errBox('Parse-Fehler'); return; }
            const iss=j&&j.data&&j.data.issue;
            if (!iss) { pane.innerHTML=errBox('Nicht gefunden (HTTP '+res.status+')'); return; }
            window._simCurrentIssueId = iss.id;
            pane.innerHTML=buildOverviewHtml(iss);
            attachAssignBtn(shortId);
        });
    }

