        pane.innerHTML = '<div style="text-align:center;padding:20px;color:#888;font-size:11px;">Lade Kommunikation…</div>';
        gqlPost({
            operationName: 'ticketThreads',
            variables: { id: shortId },
            query: `query ticketThreads($id: String!) {
  issue(id: $id) {
    id
    threads { id name createDate totalCount __typename }
    __typename
  }
}`
        }, (err, res) => {
            if (!pane.isConnected) return;
            if (err) { pane.innerHTML = errBox('Netzwerkfehler'); return; }
            let j; try { j = JSON.parse(res.responseText); } catch(e) { pane.innerHTML = errBox('Parse-Fehler'); return; }
            const threads = (j&&j.data&&j.data.issue&&j.data.issue.threads) || [];
            if (!threads.length) { pane.innerHTML = '<div style="padding:12px;color:#888;text-align:center;font-size:11px;">Keine Threads</div>'; return; }
            const updThread = threads.find(t => t.id && t.id.startsWith('updates:'));
            if (updThread) window._simThreadId = updThread.id;
            pane.innerHTML = '';
            threads.forEach(thread => {
                const section = document.createElement('div');
                section.style.cssText = 'margin-bottom:12px;';
                section.innerHTML = `<div style="font-weight:bold;font-size:11px;color:#555;padding:4px 0 6px 0;border-bottom:1px solid #e0e0e0;margin-bottom:6px;">${(thread.name||'Thread').replace(/</g,'&lt;')} <span style="font-weight:normal;color:#aaa;">(${thread.totalCount||0})</span></div>`;
                pane.appendChild(section);
                loadComments(thread.id, section);
            });
        });
