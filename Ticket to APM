                    if (!issueId || !identity) return;
                    btn.disabled = true; btn.textContent = '…';
                    gqlPost({
                        operationName: 'assignIssue',
                        variables: { issueId, assignee: identity },
                        query: `mutation assignIssue($issueId: String!, $assignee: String!) { assignIssue(issueId: $issueId, assignee: $assignee) { id __typename } }`
                    }, (err, res) => {
                        btn.disabled = false;
                        let ok = false;
                        try { const j = JSON.parse(res.responseText); ok = !!(j && j.data && j.data.assignIssue && !(j.errors && j.errors.length)); } catch(e2) {}
                        if (ok) {
                            btn.textContent = '✓'; btn.style.color = '#2e7d32'; btn.style.borderColor = '#2e7d32';
                            setTimeout(() => { btn.textContent = '👤'; btn.style.color = ''; btn.style.borderColor = ''; btn.disabled = false; }, 1800);
                            setTimeout(loadTickets, 1200);
                        } else {
                            btn.textContent = '✗'; btn.style.color = '#c00'; btn.style.borderColor = '#c00';
                            setTimeout(() => { btn.textContent = '👤'; btn.style.color = ''; btn.style.borderColor = ''; }, 2000);
                        }
                    });
                });
            });
        }
    }

