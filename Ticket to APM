    function loadComments(threadId, container) {
        gqlPost({
            operationName: 'threadComments',
            variables: { threadId, start: 0, rows: 1000, sort: 'newest_first' },
            query: `query threadComments($threadId: String!, $start: Int, $rows: Int, $sort: CommentSortOrder) {
  thread(id: $threadId) {
    id totalCount
    conversation(start: $start, rows: $rows, sort: $sort) {
      id message contentType messageType createDate
      author { id name protocol __typename }
      submitter { id name protocol __typename }
      __typename
    }
    __typename
  }
}`
        }, (err, res) => {
            if (!container.isConnected) return;
            if (err || !res || res.status !== 200) {
                container.innerHTML += '<div style="color:#c00;font-size:11px;padding:4px;">Fehler beim Laden</div>';
                return;
            }
            let j; try { j = JSON.parse(res.responseText); } catch(e) { return; }
            if (!j.data || !j.data.thread) {
                const em = j.errors ? j.errors[0].message : 'HTTP '+res.status;
                container.innerHTML += '<div style="color:#c00;font-size:11px;padding:4px;">'+em+'</div>';
                return;
            }
            const conv = j.data.thread.conversation || [];
            if (!conv.length) {
                const el = document.createElement('div');
                el.style.cssText = 'color:#aaa;font-size:11px;padding:4px;text-align:center;';
                el.textContent = 'Keine Einträge';
                container.appendChild(el);
                return;
            }
            conv.forEach(c => container.appendChild(buildCommentCard(c)));
            loadBadgePhotos(container);
        });
    }

    // Gibt Avatar-HTML zurück: Foto für kerberos-User, sonst farbiger Initialen-Kreis
    function buildAvatarHTML(author) {
        const name = (author && author.name) || '?';
        const proto = (author && author.protocol) || '';
        const initials = name.substring(0, 2).toUpperCase();
        const hue = [...name].reduce((n, c) => n + c.charCodeAt(0), 0) % 360;
        const fbStyle = `width:26px;height:26px;border-radius:50%;background:hsl(${hue},55%,42%);display:inline-flex;align-items:center;justify-content:center;font-size:10px;font-weight:bold;color:#fff;flex-shrink:0;`;
        if (proto === 'kerberos') {
            const alias = name.split('@')[0];
            return `<span style="display:inline-flex;align-items:center;width:26px;height:26px;flex-shrink:0;" title="${name}">` +
                   `<img data-badge-login="${alias}" src="" style="width:26px;height:26px;border-radius:50%;object-fit:cover;border:1px solid rgba(0,0,0,0.12);display:none;" alt="${initials}">` +
                   `<span class="sim-avatar-fb" style="${fbStyle}">${initials}</span>` +
                   `</span>`;
        }
        return `<span style="${fbStyle}" title="${name}">${initials}</span>`;
    }

    function loadBadgePhotos(container) {
        container.querySelectorAll('img[data-badge-login]').forEach(img => {
            if (img.dataset.loaded) return;
            img.dataset.loaded = '1';
            const alias = img.dataset.badgeLogin;
            GM_xmlhttpRequest({
                method: 'GET',
                url: `https://badgephotos.corp.amazon.com/?login=${alias}`,
                responseType: 'arraybuffer',
                withCredentials: true,
                onload: res => {
                    if (res.status === 200 && res.response) {
                        const blob = new Blob([res.response], { type: 'image/jpeg' });
                        img.src = URL.createObjectURL(blob);
                        img.style.display = '';
                        const fb = img.nextElementSibling;
                        if (fb) fb.style.display = 'none';
                    }
                },
                onerror: () => {}
            });
        });
    }

    function buildCommentCard(c) {
        const cfg = MSGTYPE_COLORS[c.messageType] || MSGTYPE_COLORS['DEFAULT'];
        const authorObj = c.author || c.submitter || {};
        const author = authorObj.name || '?';
        const date = c.createDate ? new Date(c.createDate).toLocaleString('de-DE') : '?';
        const msg = (c.message||'').replace(/</g,'&lt;').replace(/\n/g,'<br>');
        const card = document.createElement('div');
        card.style.cssText = `background:${cfg.bg};border:1px solid ${cfg.border};border-radius:4px;padding:8px 10px;margin-bottom:6px;font-size:11px;`;
        card.innerHTML = `<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:5px;">
  <div style="display:flex;align-items:center;gap:6px;">
    ${buildAvatarHTML(authorObj)}
    <span style="background:${cfg.badge};color:#fff;border-radius:3px;padding:1px 6px;font-size:10px;font-weight:bold;">${cfg.label}</span>
    <span style="font-weight:bold;color:#333;">${author.replace(/</g,'&lt;')}</span>
  </div>
  <span style="color:#999;font-size:10px;">${date}</span>
</div>
<div style="color:#333;line-height:1.5;">${msg}</div>`;
        return card;
