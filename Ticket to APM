    // ── Antwort senden ────────────────────────────────────────────────────────────
    // Confirmed via Debugger.getScriptSource (4141.bundle.js):
    //   mutation createCommentOnThread($args: CommentInput!) {
    //     createCommentGetComment(args: $args) { ... }
    //   }
    // contentType: 'text/plain' from webpackChunkSIMTicketingAssets mod 75403

    function sendReply(shortId, message, messageType, onDone) {
        const threadId = window._simThreadId;
        if (!threadId) {
            onDone(false, 'Thread-ID fehlt — Kommunikation-Tab neu öffnen');
            return;
        }
        gqlPost({
            operationName: 'createCommentOnThread',
            variables: {
                args: {
                    threadId,
                    contentType: 'text/plain',
                    message,
                    messageType,
                    mentions: [],
                }
            },
            query: `mutation createCommentOnThread($args: CommentInput!) {
  createCommentGetComment(args: $args) {
    id message messageType createDate
    author { id name protocol __typename }
    submitter { id name protocol __typename }
    __typename
  }
}`
        }, (err, res) => {
            if (err || !res) { onDone(false, 'Netzwerkfehler'); return; }
            let j; try { j = JSON.parse(res.responseText); } catch(e) { onDone(false, 'Parse-Fehler'); return; }
            const ok = res.status === 200 && j && j.data && j.data.createCommentGetComment
                       && !(j.errors && j.errors.length);
            if (ok) {
                onDone(true, null);
            } else {
                const errMsg = (j&&j.errors&&j.errors[0]&&j.errors[0].message) || `HTTP ${res.status}`;
                console.log('[SIM send] Fehler:', errMsg, JSON.stringify(j).substring(0,300));
                onDone(false, errMsg);
            }
        });
    }

    // ── Work Order Extraktion ─────────────────────────────────────────────────────

    function extractWO(messages) {
        for (const msg of messages) {
            let m;
            if ((m = msg.match(/workordernum=(\d+)/)))            return m[1];
            if ((m = msg.match(/WO\s+(\d{8,})/i)))               return m[1];
            if ((m = msg.match(/EAM\(APM\)[^0-9]*(\d{8,})/i)))   return m[1];
            if ((m = msg.match(/work[\s_-]*order[^0-9]*(\d{8,})/i))) return m[1];
            if ((m = msg.match(/number\s*:\s*(\d{8,})/i)))        return m[1];
        }
        return null;
    }

    function fetchWOForDoc(doc, cb) {
        const sid = doc.shortId;
        if (_woCache[sid] !== undefined) { cb(_woCache[sid]); return; }
        gqlPost({
            operationName: 'threadComments',
            variables: { threadId: 'updates:' + doc.id, start: 0, rows: 50, sort: 'oldest_first' },
            query: `query threadComments($threadId: String!, $start: Int, $rows: Int, $sort: CommentSortOrder) {
  thread(id: $threadId) {
    conversation(start: $start, rows: $rows, sort: $sort) { message __typename }
    __typename
  }
}`
        }, (err, res) => {
            let wo = null;
            if (!err && res && res.status === 200) {
                try {
                    const j = JSON.parse(res.responseText);
                    const conv = (j&&j.data&&j.data.thread&&j.data.thread.conversation) || [];
                    wo = extractWO(conv.map(c => c.message || ''));
                } catch(e) {}
            }
            _woCache[sid] = wo;
            cb(wo);
        });
    }

    function loadAllWOs(docs) {
        if (!docs || !docs.length) return;
        let idx = 0;
        function next() {
            if (idx >= docs.length) return;
            const doc = docs[idx++];
            if (_woCache[doc.shortId] !== undefined) {
                const c = document.getElementById('wo-' + doc.shortId);
                if (c) renderWOCell(c, _woCache[doc.shortId]);
                next();
                return;
            }
            fetchWOForDoc(doc, (wo) => {
                const c = document.getElementById('wo-' + doc.shortId);
                if (c) renderWOCell(c, wo);
                setTimeout(next, 120);
            });
        }
        next();
    }

    function renderWOCell(cell, wo) {
        cell.innerHTML = '';
        if (wo) {
            const a = document.createElement('a');
            a.href = EAM_WO_URL + wo;
            a.target = '_blank';
            a.textContent = wo;
            a.style.cssText = 'color:#00b8d8;font-weight:bold;font-size:10px;white-space:nowrap;text-decoration:none;';
            a.title = 'WO ' + wo + ' in EAM';
            a.addEventListener('click', e => e.stopPropagation());
            cell.appendChild(a);
        } else {
            const s = document.createElement('span');
            s.style.cssText = 'color:#bbb;font-size:10px;';
            s.textContent = '\u2014';
            cell.appendChild(s);
        }
    }

    // ── Hilfsfunktionen ───────────────────────────────────────────────────────────

    function errBox(html) {
        return `<div style="background:#fff3f3;border:1px solid #f5c2c2;border-radius:4px;padding:10px 14px;color:#c00;font-size:11px;line-height:1.5;">${html}</div>`;
    }

    function getKpiBody() {
        return document.querySelector('[id*="bsstrt_kpis"][id$="-body"]');
    }

    // ── Ticket-Liste laden ────────────────────────────────────────────────────────

    setInterval(() => {
        const kb = getKpiBody();
        if (!kb) {
            const old = document.getElementById(PANEL_ID);
            if (old) old.remove();
            _loading = false;
            return;
        }
        if (!document.getElementById(PANEL_ID)) {
            injectPanel(kb, _lastData);
            if (!_loading) loadTickets();
            return;
        }
        if (!_loading && Date.now() - _lastRefresh > REFRESH_MS) loadTickets();
    }, 1000);

    function loadTickets() {
        _loading = true;
        _lastRefresh = Date.now();
        updateStatus('Lädt...');
        gqlPost(makeListBody(_activeFilter), function(err, res) {
            _loading = false;
            if (err) { updateStatus('Netzwerkfehler'); return; }
            try {
                const json = JSON.parse(res.responseText);
                if (!json||!json.data||!json.data.queryIssues) {
                    updateStatus('Fehler');
                    const body = document.getElementById('sim-body');
                    if (body) body.innerHTML = `<div style="padding:8px;color:#c00;font-size:10px;word-break:break-all;">HTTP ${res.status} — ${JSON.stringify(json).substring(0,200)}</div>`;
                    return;
                }
                const docs = json.data.queryIssues.documents;
                _lastData = { docs, total: json.data.queryIssues.total };
                const kb = getKpiBody();
                if (kb) injectPanel(kb, _lastData);
            } catch(e) {
                updateStatus('Parse-Fehler');
            }
        });
    }

    function injectPanel(kb, data) {
        let panel = document.getElementById(PANEL_ID);
        if (!panel) {
            panel = document.createElement('div');
            panel.id = PANEL_ID;
            panel.style.cssText = 'margin:0;font-family:Arial,sans-serif;font-size:12px;';
            const kv = kb.querySelector('.x-dataview');
            if (kv) kv.style.display = 'none';
            kb.style.overflow = 'auto';
            kb.insertBefore(panel, kb.firstChild);
        }

        const now   = new Date().toLocaleTimeString('de-DE', {hour:'2-digit', minute:'2-digit'});
        const total = data ? data.total : '?';

        const tabStyle = (key) =>
            _activeFilter === key
                ? 'padding:4px 12px;font-size:11px;font-weight:bold;cursor:pointer;border:none;border-bottom:2px solid #ff9900;background:transparent;color:#fff;user-select:none;'
                : 'padding:4px 12px;font-size:11px;font-weight:bold;cursor:pointer;border:none;border-bottom:2px solid transparent;background:transparent;color:#888;user-select:none;';

        panel.innerHTML =
            `<div style="background:#232f3e;padding:5px 10px 0 10px;display:flex;align-items:center;justify-content:space-between;">` +
            `<div style="display:flex;align-items:flex-end;gap:0;">` +
            `<button id="sim-tab-ar" style="${tabStyle('ar')}">${FILTERS.ar.label}&nbsp;<span class="sim-star" data-filter="ar" title="Als Standard merken" style="opacity:${_defaultFilter==='ar'?'1':'0.3'};cursor:pointer;font-size:10px;">★</span></button>` +
            `<button id="sim-tab-all" style="${tabStyle('all')}">${FILTERS.all.label}&nbsp;<span class="sim-star" data-filter="all" title="Als Standard merken" style="opacity:${_defaultFilter==='all'?'1':'0.3'};cursor:pointer;font-size:10px;">★</span></button>` +
            `<span id="sim-total-badge" style="margin-left:8px;background:#ff9900;color:#000;border-radius:10px;padding:1px 7px;font-size:11px;align-self:center;">${total}</span>` +
            `</div>` +
            `<span style="font-size:10px;color:#aaa;display:flex;align-items:center;gap:8px;padding-bottom:4px;">` +
            `<span id="sim-status-txt">${now}</span>` +
            `<span id="sim-refresh-btn" title="Neu laden" style="color:#ff9900;cursor:pointer;font-size:16px;user-select:none;">&#8635;</span>` +
            `<a href="https://t.corp.amazon.com" target="_blank" style="color:#ff9900;font-size:13px;text-decoration:none;">&#10138;</a>` +
            `</span></div>` +
            `<div id="sim-body">${data ? buildTable(data.docs) : '<div style="padding:10px;color:#999;text-align:center;">Lade Tickets...</div>'}</div>`;

        document.getElementById('sim-refresh-btn').addEventListener('click', () => {
            if (!_loading) loadTickets();
        });
        document.getElementById('sim-tab-ar').addEventListener('click', e => {
            if (e.target.classList.contains('sim-star')) return;
            if (_activeFilter === 'ar' || _loading) return;
            _activeFilter = 'ar'; _lastData = null; loadTickets();
        });
        document.getElementById('sim-tab-all').addEventListener('click', e => {
            if (e.target.classList.contains('sim-star')) return;
            if (_activeFilter === 'all' || _loading) return;
            _activeFilter = 'all'; _lastData = null; loadTickets();
        });
        // Stern-Klick = Standardfilter setzen
        panel.querySelectorAll('.sim-star').forEach(star => {
            star.addEventListener('click', e => {
                e.stopPropagation();
                _defaultFilter = star.dataset.filter;
                localStorage.setItem('sim_default_filter', _defaultFilter);
