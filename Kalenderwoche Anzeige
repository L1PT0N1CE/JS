// ==UserScript==
// @name         Kalenderwoche Anzeige (Quip-Integrated)
// @version      2.0
// @description  Zeigt die aktuelle Kalenderwoche als integrierter Button in der Quip-Toolbar an
// @author       Kanataza (modifiziert)
// @match        https://quip-amazon.com/*
// @match        https://*.quip-amazon.com/*
// @icon         https://media.licdn.com/dms/image/v2/D4E03AQEkSQG-ayth3g/profile-displayphoto-shrink_200_200/profile-displayphoto-shrink_200_200/0/1730057709648?e=2147483647&v=beta&t=C7VGPq9vEfeuAcJa6aO7eBLN8GDKcR5c70l1ABnA3DU 
// @grant        none
// ==/UserScript==

(function() {
    'use strict';

    function getISOWeekNumber(date) {
        const tempDate = new Date(date.getTime());
        tempDate.setHours(0, 0, 0, 0);
        tempDate.setDate(tempDate.getDate() + 3 - (tempDate.getDay() + 6) % 7);
        const firstThursday = new Date(tempDate.getFullYear(), 0, 4);
        const weekNumber = Math.round((tempDate - firstThursday) / (7 * 24 * 60 * 60 * 1000)) + 1;
        return weekNumber;
    }

    function injectKWButton() {
        // Suche die Button-Gruppe (role="group")
        const buttonGroup = document.querySelector('.buttons[role="group"]');
        if (!buttonGroup) return;

        // Prüfe ob bereits eingefügt
        if (document.getElementById('kw-quip-button')) return;

        const kw = getISOWeekNumber(new Date());

        // Erstelle Button-Container (Wrapper wie bei den anderen Buttons)
        const kwWrapper = document.createElement('div');
        kwWrapper.id = 'kw-quip-button';
        kwWrapper.style.display = 'inline-flex';
        kwWrapper.style.alignItems = 'center';

        // Erstelle den eigentlichen Button
        const kwButton = document.createElement('button');
        kwButton.className = 'button button-flex clickable dark';
        kwButton.setAttribute('data-mousedown', 'no-caret-move');
        kwButton.setAttribute('aria-label', `Kalenderwoche ${kw}`);
        kwButton.style.cssText = `
            background-color: rgb(var(--quipAction));
            height: 32px;
            padding-left: 12px;
            padding-right: 12px;
            color: rgb(255, 255, 255);
            fill: rgb(255, 255, 255);
            border: none;
            border-radius: 4px;
            cursor: default;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            font-size: 14px;
            font-weight: 500;
            line-height: 32px;
            display: flex;
            align-items: center;
            gap: 6px;
            margin-right: 4px;
            user-select: none;
        `;

        // Icon (Kalender-Icon als SVG)
        const iconSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        iconSvg.setAttribute('viewBox', '0 0 24 24');
        iconSvg.setAttribute('preserveAspectRatio', 'xMidYMid');
        iconSvg.setAttribute('width', '16');
        iconSvg.setAttribute('height', '16');
        iconSvg.style.fill = 'currentColor';
        iconSvg.style.flexShrink = '0';
        iconSvg.innerHTML = `
            <path d="M19 4h-1V2h-2v2H8V2H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 16H5V10h14v10zM9 14H7v-2h2v2zm4 0h-2v-2h2v2zm4 0h-2v-2h2v2z"/>
        `;

        // Text
        const textSpan = document.createElement('span');
        textSpan.textContent = `KW ${kw}`;

        // Zusammenbauen
        kwButton.appendChild(iconSvg);
        kwButton.appendChild(textSpan);
        kwWrapper.appendChild(kwButton);

        // Füge vor dem "Freigeben"-Button oder am Ende ein
        const shareButton = buttonGroup.querySelector('.change-access-button');
        if (shareButton && shareButton.parentNode === buttonGroup) {
            buttonGroup.insertBefore(kwWrapper, shareButton);
        } else {
            buttonGroup.appendChild(kwWrapper);
        }
    }

    // Initial ausführen
    injectKWButton();

    // Aktualisiere jede Stunde
    setInterval(() => {
        const kwButton = document.getElementById('kw-quip-button');
        if (kwButton) {
            const newKw = getISOWeekNumber(new Date());
            const textSpan = kwButton.querySelector('span');
            if (textSpan) textSpan.textContent = `KW ${newKw}`;
        }
    }, 3600000);

    // MutationObserver für dynamische Seitenänderungen (SPA-Verhalten)
    const observer = new MutationObserver((mutations) => {
        injectKWButton();
    });
    
    observer.observe(document.body, {
        childList: true,
        subtree: true
    });
})();
